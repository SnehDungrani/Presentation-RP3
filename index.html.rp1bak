    <div
      class="lightbox"
      id="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Diagram enlarged"
    >
      <span class="close-hint">esc to close</span>
      <object
        type="image/svg+xml"
        data="assets/today-vs-interact.svg"
        aria-label="Today versus INTER.act architecture diagram (enlarged)"
      ></object>
    </div>

    <div
      class="lightbox"
      id="archLightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Architecture diagram enlarged"
    >
      <span class="close-hint">esc to close</span>
      <div class="arch-lightbox-inner"></div>
    </div>

    <script>
      /* Combined-view controller - observer + dots + keys + progress */
      class Combined {
        constructor() {
          this.slides = Array.from(document.querySelectorAll(".slide"));
          this.current = 0;
          this.progress = document.getElementById("progress");
          this.dots = document.getElementById("navDots");
          this.buildDots();
          this.observe();
          this.bindKeys();
        }
        buildDots() {
          this.slides.forEach((_, i) => {
            const b = document.createElement("button");
            b.setAttribute("aria-label", `Go to slide ${i + 1}`);
            if (i === 0) b.classList.add("active");
            b.addEventListener("click", () => this.goTo(i));
            this.dots.appendChild(b);
          });
        }
        observe() {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  e.target.classList.add("visible");
                  const idx = this.slides.indexOf(e.target);
                  if (idx >= 0) {
                    this.current = idx;
                    this.updateDots();
                    this.updateProgress();
                  }
                }
              });
            },
            { threshold: 0.5 },
          );
          this.slides.forEach((s) => io.observe(s));
        }
        updateDots() {
          Array.from(this.dots.children).forEach((b, i) =>
            b.classList.toggle("active", i === this.current),
          );
        }
        updateProgress() {
          this.progress.style.width =
            ((this.current + 1) / this.slides.length) * 100 + "%";
        }
        goTo(i) {
          if (i < 0 || i >= this.slides.length) return;
          this.slides[i].scrollIntoView({ behavior: "smooth" });
        }
        bindKeys() {
          document.addEventListener("keydown", (e) => {
            if (
              e.key === "ArrowDown" ||
              e.key === "PageDown" ||
              e.key === " "
            ) {
              e.preventDefault();
              this.goTo(this.current + 1);
            } else if (e.key === "ArrowUp" || e.key === "PageUp") {
              e.preventDefault();
              this.goTo(this.current - 1);
            } else if (e.key === "Home") {
              e.preventDefault();
              this.goTo(0);
            } else if (e.key === "End") {
              e.preventDefault();
              this.goTo(this.slides.length - 1);
            }
          });
        }
      }
      document.addEventListener("DOMContentLoaded", () => new Combined());

      /* Lightbox: click diagram → enlarge; backdrop / Esc → close. */
      (function () {
        const frame = document.getElementById("diagramFrame");
        const lb = document.getElementById("lightbox");
        const archFrame = document.getElementById("archFrame");
        const archLb = document.getElementById("archLightbox");

        function setupLightbox(trigger, box, cloneSvg) {
          if (!trigger || !box) return;
          const open = () => {
            if (cloneSvg) {
              const svg = trigger.querySelector("svg.arch-svg");
              const inner = box.querySelector(".arch-lightbox-inner");
              if (svg && inner) {
                inner.innerHTML = "";
                const clone = svg.cloneNode(true);
                clone.removeAttribute("class");
                clone.style.width = "98vw";
                clone.style.maxHeight = "94vh";
                clone.style.background = "white";
                clone.style.borderRadius = "4px";
                inner.appendChild(clone);
              }
            }
            box.classList.add("open");
          };
          const close = () => box.classList.remove("open");
          trigger.addEventListener("click", open);
          trigger.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              open();
            }
          });
          box.addEventListener("click", close);
        }

        setupLightbox(frame, lb, false);
        setupLightbox(archFrame, archLb, true);

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            if (lb) lb.classList.remove("open");
            if (archLb) archLb.classList.remove("open");
          }
        });
      })();
    </script>
  </body>
</html>
